<Window x:Class="FeilingPetShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title=""
        Width="220"
        Height="320"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
        <Grid Background="Transparent">
        <Grid Margin="0,0,40,0">
            <Grid x:Name="PetDragSurface"
                  Width="200"
                  Height="300"
                  VerticalAlignment="Bottom"
                  Background="#01000000"
                  ClipToBounds="True"
                  RenderTransformOrigin="0.5,1"
                  MouseEnter="PetDragSurface_OnMouseEnter"
                  MouseLeave="PetDragSurface_OnMouseLeave"
                  MouseLeftButtonDown="OnShellMouseLeftButtonDown"
                  MouseMove="OnShellMouseMove"
                  MouseLeftButtonUp="OnShellMouseLeftButtonUp">
                <Grid.CacheMode>
                    <BitmapCache />
                </Grid.CacheMode>
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="PetScaleTransform" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="PetTranslateTransform" X="0" Y="0" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <Image x:Name="PetImage"
                       Width="200"
                       Height="300"
                       Stretch="Uniform"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <Image x:Name="BlinkOverlayImage"
                       Width="200"
                       Height="300"
                       Stretch="Uniform"
                       VerticalAlignment="Bottom"
                       Visibility="Collapsed"
                       IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Grid>
        </Grid>

        <Grid HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="0,0,0,0"
              Width="38">
            <Popup x:Name="MenuPopup"
                   PlacementTarget="{Binding ElementName=MenuButton}"
                   Placement="Left"
                   HorizontalOffset="-4"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   Closed="MenuPopup_OnClosed">
                <Border Background="#F8FFF7F2"
                        BorderBrush="#28875D53"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="12"
                        Width="186">
                    <StackPanel>
                        <TextBlock Text="绯铃"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#FF3D2925" />
                        <TextBlock Text="先陪着你。要说话的话，点我就行。"
                                   Margin="0,4,0,12"
                                   FontSize="11"
                                   Foreground="#B83D2925"
                                   TextWrapping="Wrap" />

                        <Border Background="#FFF7EEE7"
                                CornerRadius="12"
                                Padding="10,8"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="移动模式"
                                           FontSize="11"
                                           Foreground="#9A5E4843" />
                                <TextBlock x:Name="MovementModeText"
                                           Text="当前：固定位置"
                                           Margin="0,2,0,0"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#FF69403A" />
                            </StackPanel>
                        </Border>

                        <Button x:Name="GreetButton"
                                Click="GreetButton_OnClick"
                                Cursor="Hand"
                                Background="#FFD35F67"
                                BorderThickness="0"
                                Padding="12,10"
                                HorizontalContentAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="14">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <DockPanel>
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#FFFFF5CF"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"
                                         DockPanel.Dock="Right" />
                                <StackPanel>
                                    <TextBlock Text="打个招呼"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="White" />
                                    <TextBlock Text="让绯铃说一句话"
                                               Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="#E6FFFFFF" />
                                </StackPanel>
                            </DockPanel>
                        </Button>

                        <Button x:Name="WanderButton"
                                Click="WanderButton_OnClick"
                                Cursor="Hand"
                                Background="#FFF6EEE6"
                                BorderBrush="#30AF705F"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="0,8,0,0"
                                HorizontalContentAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="14">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel>
                                <TextBlock Text="开始闲逛"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#FF7A5345" />
                                <TextBlock Text="让绯铃走走停停地看看桌面"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="#B87A5345" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="FollowMouseButton"
                                Click="FollowMouseButton_OnClick"
                                Cursor="Hand"
                                Background="#FFF6EEE6"
                                BorderBrush="#30AF705F"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="0,8,0,0"
                                HorizontalContentAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="14">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel>
                                <TextBlock Text="追逐鼠标"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#FF7A5345" />
                                <TextBlock Text="让绯铃慢慢跟着你的鼠标走"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="#B87A5345" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="PinPositionButton"
                                Click="PinPositionButton_OnClick"
                                Cursor="Hand"
                                Background="#FFF6EEE6"
                                BorderBrush="#30AF705F"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="0,8,0,0"
                                HorizontalContentAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="14">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel>
                                <TextBlock Text="固定位置"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#FF7A5345" />
                                <TextBlock Text="关闭主动移动，停在当前位置"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="#B87A5345" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="ExitPetButton"
                                Click="ExitPetButton_OnClick"
                                Cursor="Hand"
                                Background="#FFF4E7E1"
                                BorderBrush="#30AF705F"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="0,8,0,0"
                                HorizontalContentAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="14">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <DockPanel>
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#FFB74953"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"
                                         DockPanel.Dock="Right" />
                                <StackPanel>
                                    <TextBlock Text="退出绯铃"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#FF7A3A3A" />
                                    <TextBlock Text="关闭当前桌宠窗口"
                                               Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="#B87A3A3A" />
                                </StackPanel>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <Button x:Name="MenuButton"
                    Width="34"
                    Height="34"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Background="#FFF7C6BA"
                    BorderBrush="#30AF705F"
                    BorderThickness="1"
                    Click="MenuButton_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <Grid>
                                <Rectangle Width="14"
                                           Height="2"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="#FFB74953"
                                           VerticalAlignment="Center"
                                           Margin="0,-6,0,0" />
                                <Rectangle Width="14"
                                           Height="2"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="#FFB74953"
                                           VerticalAlignment="Center" />
                                <Rectangle Width="14"
                                           Height="2"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="#FFB74953"
                                           VerticalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
